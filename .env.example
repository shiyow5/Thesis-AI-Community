# === Discord ===
# 受信用 Bot のトークン（Discord Developer Portal で作成）
DISCORD_BOT_TOKEN=
# 議論を投稿する対象サーバー / チャンネル ID
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=

# === ペルソナ投稿用 Webhook（対象チャンネルに作成した Webhook URL）===
WEBHOOK_PROFESSOR=
WEBHOOK_EXPERT=
WEBHOOK_GRAD_STUDENT=
WEBHOOK_LAYPERSON=

# === LLM ===
# Google AI Studio の API キー（Gemma 4 / Gemini 2.5 Flash 共通）
GEMINI_API_KEY=
# ローカルフォールバック（LM Studio / Ollama の OpenAI 互換エンドポイント）
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=

# === 議論ポリシー ===
# 1 つの論文につき各ペルソナが発言するラウンドの上限。
# 司会判定で論点が出尽くせば上限前でも終了する。大きいほど深く議論するが API 消費も増える。
DISCUSSION_MAX_ROUNDS=4

# === 任意 ===
# 論文ソース API のレート制御に使う連絡先（Crossref polite pool など）
CONTACT_EMAIL=
